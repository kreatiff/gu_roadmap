# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── OIDC (University SSO) ──────────────────────────────────────────────────────
# Leave empty to skip OIDC and use the dev-login bypass instead
OIDC_ISSUER=
OIDC_CLIENT_ID=gu-roadmap
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3001/api/auth/callback

# ── Security ───────────────────────────────────────────────────────────────────
# Must be at least 32 characters
JWT_SECRET=change-me-to-at-least-32-characters-abc
COOKIE_SECRET=change-me-to-at-least-32-characters-xyz

# ── CORS / Frontend ────────────────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173

# ── Admin Access ───────────────────────────────────────────────────────────────
# Comma-separated list of emails that get admin privileges
ADMIN_EMAILS=o.estrin@griffith.edu.au

# ── Azure Cosmos DB ────────────────────────────────────────────────────────────
# Cosmos DB for NoSQL (document API)
# For local dev use the Cosmos DB Emulator (https://aka.ms/cosmosdb-emulator)
#   Emulator endpoint: https://localhost:8081
#   Emulator key:      C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b7u8kTMKxPh8ISbMpLrMjERHOy8vEAQ==
COSMOS_ENDPOINT=https://<account>.documents.azure.com:443/
COSMOS_KEY=<primary-or-secondary-key>
COSMOS_DATABASE_ID=gu_roadmap
